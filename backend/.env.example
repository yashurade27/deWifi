PORT=3000

# Local MongoDB (single machine only)
# MONGO_URI=mongodb://localhost:27017/airlink

# MongoDB Atlas (shared cloud DB - recommended for teams)
# Replace <user>, <password>, and <cluster> with your Atlas credentials
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/airlink?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_this
CLIENT_URL=http://localhost:5173

# Razorpay Test Credentials
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
